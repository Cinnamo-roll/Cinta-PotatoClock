{
  "name": "potato-clock",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:landing": "cross-env VITE_APP_TARGET=landing vite --host 127.0.0.1",
    "dev:app": "cross-env VITE_APP_TARGET=app vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "build:landing": "cross-env VITE_APP_TARGET=landing tsc -b && cross-env VITE_APP_TARGET=landing vite build",
    "build:app": "cross-env VITE_APP_TARGET=app VITE_API_BASE_URL=https://clock.cinoo.xyz/api VITE_USE_MOCK=false tsc -b && cross-env VITE_APP_TARGET=app VITE_API_BASE_URL=https://clock.cinoo.xyz/api VITE_USE_MOCK=false vite build",
    "preview": "vite preview --host 127.0.0.1",
    "cap:init": "cap init",
    "cap:sync": "pnpm build:app && cap sync",
    "cap:ios": "pnpm build:app && cap sync ios && cap open ios",
    "cap:android": "pnpm build:app && cap sync android && cap open android"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.4.1",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/inappbrowser": "^4.0.0",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/network": "^8.0.1",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tanstack/react-query": "^5.90.11",
    "axios": "^1.13.2",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "lucide-react": "^0.555.0",
    "motion": "^12.23.24",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.6",
    "recharts": "^3.5.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "vaul": "^1.1.2",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.22",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "vite": "^7.2.4"
  },
  "packageManager": "pnpm@10.22.0"
}
